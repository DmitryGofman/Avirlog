# Copy to .env for local runs; on a host, set these as environment variables.

# MongoDB connection string (e.g. from MongoDB Atlas).
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Database name.
DB_NAME=avirlog

# Long random string used to sign JWTs. Generate one, keep it secret.
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated CORS allowlist. "*" is fine (auth uses Bearer tokens, not cookies).
CORS_ORIGINS=*

# Leave Google sign-in OFF for v1 (email/password only). The Google path depends
# on an Emergent sandbox and is not production-ready.
EMERGENT_GOOGLE_ENABLED=false
